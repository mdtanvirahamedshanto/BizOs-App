# BizOs mobile app environment.
# Copy to `.env` for local development. For release builds, set these per
# profile in eas.json (EAS Build) — values prefixed with EXPO_PUBLIC_ are
# embedded in the JS bundle at build time.

# REST API base URL (must include the /api/v1 prefix).
#  - Android emulator -> http://10.0.2.2:4000/api/v1
#  - iOS simulator    -> http://localhost:4000/api/v1
#  - Physical device  -> http://<your-LAN-IP>:4000/api/v1
#  - Production        -> https://api.your-domain.com/api/v1   (HTTPS required)
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api/v1

# Realtime socket base URL (no /api/v1 suffix).
EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:4000
