{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:4000/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "http://10.0.2.2:4000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging-api.your-domain.com/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://staging-api.your-domain.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.your-domain.com/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.your-domain.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
